CONFIG_TARGET_airoha=y
CONFIG_TARGET_airoha_an7581=y
CONFIG_TARGET_airoha_an7581_DEVICE_nokia_xg-040g-md=y
# 不要选UBI版本
# CONFIG_TARGET_airoha_an7581_DEVICE_nokia_xg-040g-md-ubi is not set

#=============================================
# 核心硬件驱动（必须，否则硬件无法工作）
#=============================================
# NPU固件和2.5G PHY驱动
CONFIG_airoha-en7581-npu-firmware=y
CONFIG_kmod-phy-airoha-en8811h=y
CONFIG_airoha-en8811h-firmware=y
# I2C总线驱动（硬件必须）
CONFIG_PACKAGE_kmod-i2c-an7581=y
# LED驱动和GPIO按键
CONFIG_PACKAGE_kmod-leds-gpio=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_kmod-usb-ledtrig-usbport=y
# USB完整驱动（xHCI主控制器必须）
CONFIG_USB_SUPPORT=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y

#=============================================
# 存储系统支持
#=============================================
# 块设备挂载（USB硬盘/U盘必须）
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_fitblk=y
# MTD分区和NAND支持
CONFIG_PACKAGE_mtd=y
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_kmod-ubootenv-nvram=y
CONFIG_PACKAGE_ubi-utils=y
CONFIG_MTD_UBI=y
CONFIG_UBIFS_FS=y
# 文件系统工具
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_e2fsprogs=y

#=============================================
# 网络加速和防火墙
#=============================================
# FullCone NAT和硬件转发加速
CONFIG_PACKAGE_kmod-nft-fullcone=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-nft-nat=y
# nftables核心模块
CONFIG_PACKAGE_kmod-nfnetlink=y
CONFIG_PACKAGE_kmod-nft-core=y
# 透明代理支持（HomeProxy必须）
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nf-socket=y
# 网络工具
CONFIG_PACKAGE_ethtool-full=y
CONFIG_PACKAGE_ip-full=y

#=============================================
# LuCI 基础
#=============================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-compat=y

#=============================================
# 系统管理插件
#=============================================
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-i18n-store-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

#=============================================
# 核心功能插件
#=============================================
CONFIG_PACKAGE_luci-app-appfilter=y
CONFIG_PACKAGE_luci-i18n-appfilter-zh-cn=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y
CONFIG_PACKAGE_luci-app-ddnsto=y
CONFIG_PACKAGE_luci-i18n-ddnsto-zh-cn=y
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_luci-app-airoha-npu=y
CONFIG_PACKAGE_luci-i18n-airoha-npu-zh-cn=y

#=============================================
# 系统优化
#=============================================
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
# CONFIG_PACKAGE_wget is not set

#=============================================
# 全文件系统支持
#=============================================
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
# Disable unused packages
# CONFIG_PACKAGE_luci-app-frpc is not set
# CONFIG_PACKAGE_luci-app-frps is not set
# CONFIG_PACKAGE_luci-app-iptvhelper is not set
# CONFIG_PACKAGE_luci-app-iptv is not set
CONFIG_CCACHE=y
CONFIG_CCACHE_DIR="ccache"
CONFIG_CCACHE_MAXSIZE="2G"
